<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysCouponMapper">
    <resultMap type="SysCoupon" id="SysCouponResult">
        <id property="couponId" column="coupon_id" />
        <result property="couponName" column="coupon_name" />
        <result property="couponType" column="coupon_type" />
        <result property="discountValue" column="discount_value" />
        <result property="minAmount" column="min_amount" />
        <result property="status" column="status" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectSysCouponVo">
        select coupon_id, coupon_name, coupon_type, discount_value, min_amount, status, start_time, end_time, remark, create_by, create_time, update_by, update_time from sys_coupon
    </sql>

    <select id="selectSysCouponById" parameterType="Long" resultMap="SysCouponResult">
        <include refid="selectSysCouponVo" />
        where coupon_id = #{couponId}
    </select>

    <select id="selectSysCouponList" parameterType="SysCoupon" resultMap="SysCouponResult">
        <include refid="selectSysCouponVo" />
        <where>
            <if test="couponName != null and couponName != ''">
                AND coupon_name like concat('%', #{couponName}, '%')
            </if>
            <if test="couponType != null and couponType != ''">
                AND coupon_type = #{couponType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertSysCoupon" parameterType="SysCoupon" useGeneratedKeys="true" keyProperty="couponId">
        insert into sys_coupon(coupon_name, coupon_type, discount_value, min_amount, status, start_time, end_time, remark, create_by, create_time, update_by, update_time)
        values(#{couponName}, #{couponType}, #{discountValue}, #{minAmount}, #{status}, #{startTime}, #{endTime}, #{remark}, #{createBy}, #{createTime}, #{updateBy}, #{updateTime})
    </insert>

    <update id="updateSysCoupon" parameterType="SysCoupon">
        update sys_coupon
        <set>
            <if test="couponName != null and couponName != ''">
                coupon_name = #{couponName},
            </if>
            <if test="couponType != null and couponType != ''">
                coupon_type = #{couponType},
            </if>
            <if test="discountValue != null">
                discount_value = #{discountValue},
            </if>
            <if test="minAmount != null">
                min_amount = #{minAmount},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            <if test="startTime != null">
                start_time = #{startTime},
            </if>
            <if test="endTime != null">
                end_time = #{endTime},
            </if>
            <if test="remark != null and remark != ''">
                remark = #{remark},
            </if>
            update_by = #{updateBy},
            update_time = #{updateTime}
        </set>
        where coupon_id = #{couponId}
    </update>

    <delete id="deleteSysCouponById" parameterType="Long">
        delete from sys_coupon where coupon_id = #{couponId}
    </delete>

    <delete id="deleteSysCouponByIds" parameterType="Long[]">
        delete from sys_coupon where coupon_id in
        <foreach item="couponId" collection="array" open="(" separator="," close=")">
            #{couponId}
        </foreach>
    </delete>

    <update id="updateSysCouponStatus">
        update sys_coupon set status = #{status} where coupon_id in
        <foreach item="couponId" collection="couponIds" open="(" separator="," close=")">
            #{couponId}
        </foreach>
    </update>
</mapper>