<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysMemberMapper">
    <resultMap type="SysMember" id="SysMemberResult">
        <id property="memberId" column="member_id" />
        <result property="memberName" column="member_name" />
        <result property="memberCode" column="member_code" />
        <result property="phone" column="phone" />
        <result property="email" column="email" />
        <result property="birthdate" column="birthdate" />
        <result property="gender" column="gender" />
        <result property="address" column="address" />
        <result property="totalPoints" column="total_points" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectSysMemberVo">
        select member_id, member_name, member_code, phone, email, birthdate, gender, address, total_points, status, remark, create_by, create_time, update_by, update_time 
        from sys_member
    </sql>

    <select id="selectSysMemberById" parameterType="Long" resultMap="SysMemberResult">
        <include refid="selectSysMemberVo" />
        where member_id = #{memberId}
    </select>

    <select id="selectSysMemberByPhone" parameterType="String" resultMap="SysMemberResult">
        <include refid="selectSysMemberVo" />
        where phone = #{phone}
    </select>

    <select id="selectSysMemberList" parameterType="SysMember" resultMap="SysMemberResult">
        <include refid="selectSysMemberVo" />
        <where>
            <if test="memberName != null and memberName != ''">
                AND member_name like concat('%', #{memberName}, '%')
            </if>
            <if test="memberCode != null and memberCode != ''">
                AND member_code like concat('%', #{memberCode}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone like concat('%', #{phone}, '%')
            </if>
            <if test="email != null and email != ''">
                AND email like concat('%', #{email}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertSysMember" parameterType="SysMember" useGeneratedKeys="true" keyProperty="memberId">
        insert into sys_member(member_name, member_code, phone, email, birthdate, gender, address, total_points, status, remark, create_by, create_time, update_by, update_time)
        values(#{memberName}, #{memberCode}, #{phone}, #{email}, #{birthdate}, #{gender}, #{address}, #{totalPoints}, #{status}, #{remark}, #{createBy}, #{createTime}, #{updateBy}, #{updateTime})
    </insert>

    <update id="updateSysMember" parameterType="SysMember">
        update sys_member
        <set>
            <if test="memberName != null and memberName != ''">
                member_name = #{memberName},
            </if>
            <if test="memberCode != null and memberCode != ''">
                member_code = #{memberCode},
            </if>
            <if test="phone != null and phone != ''">
                phone = #{phone},
            </if>
            <if test="email != null and email != ''">
                email = #{email},
            </if>
            <if test="birthdate != null">
                birthdate = #{birthdate},
            </if>
            <if test="gender != null and gender != ''">
                gender = #{gender},
            </if>
            <if test="address != null and address != ''">
                address = #{address},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            <if test="remark != null and remark != ''">
                remark = #{remark},
            </if>
            update_by = #{updateBy},
            update_time = #{updateTime}
        </set>
        where member_id = #{memberId}
    </update>

    <update id="updateSysMemberPoints" parameterType="SysMember">
        update sys_member
        set total_points = total_points + #{totalPoints},
            update_by = #{updateBy},
            update_time = #{updateTime}
        where member_id = #{memberId}
    </update>

    <delete id="deleteSysMemberById" parameterType="Long">
        delete from sys_member where member_id = #{memberId}
    </delete>

    <delete id="deleteSysMemberByIds" parameterType="Long[]">
        delete from sys_member where member_id in
        <foreach item="memberId" collection="array" open="(" separator="," close=")">
            #{memberId}
        </foreach>
    </delete>
</mapper>