<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPackageMapper">
    <resultMap type="com.ruoyi.system.domain.SysPackage" id="SysPackageResult">
        <id property="packageId" column="package_id"/>
        <result property="packageName" column="package_name"/>
        <result property="packageCode" column="package_code"/>
        <result property="price" column="price"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectPackageVo">
        select package_id, package_name, package_code, price, status, remark, create_by, create_time, update_by, update_time
        from sys_package
    </sql>

    <select id="selectPackageList" parameterType="com.ruoyi.system.domain.SysPackage" resultMap="SysPackageResult">
        <include refid="selectPackageVo"/>
        <where>
            <if test="packageName != null and packageName != ''">
                and package_name like concat('%', #{packageName}, '%')
            </if>
            <if test="packageCode != null and packageCode != ''">
                and package_code like concat('%', #{packageCode}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPackageById" parameterType="Long" resultMap="SysPackageResult">
        <include refid="selectPackageVo"/>
        where package_id = #{packageId}
    </select>

    <insert id="insertPackage" parameterType="com.ruoyi.system.domain.SysPackage" useGeneratedKeys="true" keyProperty="packageId">
        insert into sys_package
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="packageName != null">package_name,</if>
            <if test="packageCode != null">package_code,</if>
            <if test="price != null">price,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="packageName != null">#{packageName},</if>
            <if test="packageCode != null">#{packageCode},</if>
            <if test="price != null">#{price},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updatePackage" parameterType="com.ruoyi.system.domain.SysPackage">
        update sys_package
        <set>
            <if test="packageName != null">package_name = #{packageName},</if>
            <if test="packageCode != null">package_code = #{packageCode},</if>
            <if test="price != null">price = #{price},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where package_id = #{packageId}
    </update>

    <delete id="deletePackageById" parameterType="Long">
        delete from sys_package where package_id = #{packageId}
    </delete>

    <delete id="deletePackageByIds" parameterType="Long[]">
        delete from sys_package where package_id in
        <foreach item="packageId" collection="array" open="(" separator="," close=")">
            #{packageId}
        </foreach>
    </delete>
</mapper>