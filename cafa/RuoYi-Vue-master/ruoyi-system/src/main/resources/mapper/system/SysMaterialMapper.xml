<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysMaterialMapper">
    <resultMap type="com.ruoyi.system.domain.SysMaterial" id="SysMaterialResult">
        <id property="materialId" column="material_id"/>
        <result property="materialName" column="material_name"/>
        <result property="specification" column="specification"/>
        <result property="unit" column="unit"/>
        <result property="warningThreshold" column="warning_threshold"/>
        <result property="currentStock" column="current_stock"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectSysMaterialVo">
        select material_id, material_name, specification, unit, warning_threshold, current_stock, status, create_by, create_time, update_by, update_time, remark from sys_material
    </sql>

    <select id="selectSysMaterialById" parameterType="Long" resultMap="SysMaterialResult">
        <include refid="selectSysMaterialVo"/>
        where material_id = #{materialId}
    </select>

    <select id="selectSysMaterialList" parameterType="com.ruoyi.system.domain.SysMaterial" resultMap="SysMaterialResult">
        <include refid="selectSysMaterialVo"/>
        <where>
            <if test="materialName != null and materialName != ''">
                and material_name like concat('%', #{materialName}, '%')
            </if>
            <if test="specification != null and specification != ''">
                and specification like concat('%', #{specification}, '%')
            </if>
            <if test="unit != null and unit != ''">
                and unit = #{unit}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by material_name
    </select>

    <select id="selectLowStockMaterials" resultMap="SysMaterialResult">
        <include refid="selectSysMaterialVo"/>
        where current_stock &lt;= warning_threshold and status = '0'
        order by current_stock asc
    </select>

    <insert id="insertSysMaterial" parameterType="com.ruoyi.system.domain.SysMaterial" useGeneratedKeys="true" keyProperty="materialId">
        insert into sys_material
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="materialName != null">material_name,</if>
            <if test="specification != null">specification,</if>
            <if test="unit != null">unit,</if>
            <if test="warningThreshold != null">warning_threshold,</if>
            <if test="currentStock != null">current_stock,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="materialName != null">#{materialName},</if>
            <if test="specification != null">#{specification},</if>
            <if test="unit != null">#{unit},</if>
            <if test="warningThreshold != null">#{warningThreshold},</if>
            <if test="currentStock != null">#{currentStock},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysMaterial" parameterType="com.ruoyi.system.domain.SysMaterial">
        update sys_material
        <set>
            <if test="materialName != null">material_name = #{materialName},</if>
            <if test="specification != null">specification = #{specification},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="warningThreshold != null">warning_threshold = #{warningThreshold},</if>
            <if test="currentStock != null">current_stock = #{currentStock},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where material_id = #{materialId}
    </update>

    <update id="updateMaterialStock" parameterType="com.ruoyi.system.domain.SysMaterial">
        update sys_material
        set current_stock = #{currentStock}
        where material_id = #{materialId}
    </update>

    <delete id="deleteSysMaterialById" parameterType="Long">
        delete from sys_material where material_id = #{materialId}
    </delete>

    <delete id="deleteSysMaterialByIds" parameterType="Long[]">
        delete from sys_material where material_id in 
        <foreach item="materialId" collection="array" open="(" separator="," close=")">
            #{materialId}
        </foreach>
    </delete>
</mapper>