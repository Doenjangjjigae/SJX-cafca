<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysProductMaterialOptionMapper">
    <resultMap type="com.ruoyi.system.domain.SysProductMaterialOption" id="SysProductMaterialOptionResult">
        <id property="id" column="id"/>
        <result property="productMaterialId" column="product_material_id"/>
        <result property="optionLabel" column="option_label"/>
        <result property="quantity" column="quantity"/>
    </resultMap>

    <sql id="selectOptionVo">
        select id, product_material_id, option_label, quantity
        from sys_product_material_option
    </sql>

    <select id="selectOptionsByProductMaterialId" parameterType="Long" resultMap="SysProductMaterialOptionResult">
        <include refid="selectOptionVo"/>
        where product_material_id = #{productMaterialId}
        order by id
    </select>

    <insert id="insertOption" parameterType="com.ruoyi.system.domain.SysProductMaterialOption" useGeneratedKeys="true" keyProperty="id">
        insert into sys_product_material_option (product_material_id, option_label, quantity)
        values (#{productMaterialId}, #{optionLabel}, #{quantity})
    </insert>

    <insert id="batchInsertOptions" parameterType="java.util.List">
        insert into sys_product_material_option (product_material_id, option_label, quantity)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.productMaterialId}, #{item.optionLabel}, #{item.quantity})
        </foreach>
    </insert>

    <delete id="deleteOptionsByProductMaterialId" parameterType="Long">
        delete from sys_product_material_option where product_material_id = #{productMaterialId}
    </delete>

    <delete id="deleteOptionsByProductMaterialIds">
        delete from sys_product_material_option where product_material_id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
